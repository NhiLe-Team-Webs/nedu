# =====================================================
# SUPABASE DATABASE CONFIGURATION
# Get these values from your Supabase project dashboard
# https://supabase.com/dashboard/project/[your-project]/settings/api
# =====================================================

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (public, used on client-side)
SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (secret, used on server-side only!)
# WARNING: Never expose this key on the client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# SEPAY PAYMENT GATEWAY CONFIGURATION
# Get these values from https://my.sepay.vn
# =====================================================

# API Key used for accessing SePay APIs
SEPAY_API_KEY=

# Your Bank Account Number registered with SePay
SEPAY_ACCOUNT_NUMBER=

# Bank Code (e.g., MB, VCB, ACB)
SEPAY_BANK_CODE=MB

# Webhook Secret for verifying payment notifications
# IMPORTANT: This must match the secret in your SePay Webhook settings!
SEPAY_WEBHOOK_SECRET=

# Public URL of your application (used for generating callback URLs)
# In local development, you might use localhost or an ngrok URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable debug logging for SePay (true/false)
SEPAY_DEBUG=true

# Google Sheets Configuration
# Create a Service Account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Share your sheet with the service account email (give Editor access)

# Service Account Email (e.g., my-service-account@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private Key (Copy the entire key including -----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----)
# Note: In Vercel env vars, you can paste the newlines directly. 
# In .env.local file, you might need to use \n or wrap in quotes properly.
GOOGLE_PRIVATE_KEY=

# ID of the Google Sheet (found in the URL)
# https://docs.google.com/spreadsheets/d/[THIS_IS_THE_ID]/edit
GOOGLE_SHEET_ID=198NMupt0ouMMo8M7Kyn2sRddjaduPL3tYbCFfAGV0nU

# =====================================================
# TELEGRAM NOTIFICATION CONFIGURATION
# Create a bot with @BotFather on Telegram
# =====================================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Chat ID to send notifications to (can be user ID or group ID)
# To get chat ID: send a message to your bot, then visit
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
