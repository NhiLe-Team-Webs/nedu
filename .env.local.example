# SePay Configuration
# Get these values from https://my.sepay.vn

# API Key used for accessing SePay APIs
SEPAY_API_KEY=

SEPAY_BUSINESS_ACCOUNT_NUMBER=
SEPAY_BUSINESS_BANK_CODE=

SEPAY_PERSONAL_ACCOUNT_NUMBER=
SEPAY_PERSONAL_BANK_CODE=

# Webhook API Key for verifying payment notifications
# SePay sends: "Authorization: Apikey <YOUR_KEY>"
# Set this to your API Key configured in SePay webhook settings
SEPAY_WEBHOOK_API_KEY=

# Public URL of your application (used for generating callback URLs)
# In local development, you might use localhost or an ngrok URL
NEXT_PUBLIC_APP_URL=https://nedu.nhi.sg

# Enable debug logging for SePay (true/false)
SEPAY_DEBUG=true

# Service Account Email (e.g., my-service-account@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private Key (Copy the entire key including -----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----)
# Note: In Vercel env vars, you can paste the newlines directly. 
# In .env.local file, you might need to use \n or wrap in quotes properly.
GOOGLE_PRIVATE_KEY=
# ID of the Google Sheet (found in the URL)
# https://docs.google.com/spreadsheets/d/[THIS_IS_THE_ID]/edit
GOOGLE_SHEET_ID=

# Supabase Project URL
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_SUPABASE_SERVICE_ROLE_KEY=
# ⚠️ SEPAY TEST MODE - Set to 'true' to override payment amount for testing
# Remove or set to 'false' before deploying to production!
SEPAY_TEST_MODE=
SEPAY_TEST_AMOUNT=2000
